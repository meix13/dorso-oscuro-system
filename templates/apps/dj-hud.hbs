<style>
    /* Forzamos que la barra de scroll sea siempre visible y de color rojo */
    .cartas-vivas-scroll::-webkit-scrollbar {
        width: 6px;
        display: block !important;
    }
    .cartas-vivas-scroll::-webkit-scrollbar-track {
        background: rgba(0,0,0,0.3);
        border-radius: 10px;
    }
    .cartas-vivas-scroll::-webkit-scrollbar-thumb {
        background: #8b0000;
        border-radius: 10px;
        border: 1px solid #ff4444;
    }
    /* Aseguramos que el cuerpo principal del HUD también scrollee si hay muchos jugadores */
    .dj-body {
        overflow-y: auto !important;
    }
</style>

<div class="dj-hud-container flexrow" style="background: rgba(20,20,20,0.95); color: white; border: 2px solid #8b0000; border-radius: 8px;">
    {{!-- NAVEGACIÓN LATERAL (Forzada en columna vertical, centrada y compacta) --}}
    <nav class="dj-tabs tabs" data-group="primary" style="display: flex; flex-direction: column !important; flex: 0 0 50px; background: rgba(139,0,0,0.15); border-right: 2px solid #8b0000; align-items: center; justify-content: center; gap: 25px;">

        <a class="item" data-tab="radar" style="writing-mode: vertical-rl; transform: rotate(180deg); color: #ff4444; font-weight: bold; cursor: pointer; font-size: 11px; text-decoration: none; letter-spacing: 1px;">
            <i class="fas fa-eye" style="margin-bottom: 6px; transform: rotate(90deg); font-size: 13px;"></i> JUGADORES
        </a>

        <a class="item" data-tab="criatura" style="writing-mode: vertical-rl; transform: rotate(180deg); color: #ffaa00; font-weight: bold; cursor: pointer; font-size: 11px; text-decoration: none; letter-spacing: 1px;">
            <i class="fas fa-dragon" style="margin-bottom: 6px; transform: rotate(90deg); font-size: 13px;"></i> CRIATURA
        </a>

        <a class="item" data-tab="equipo" style="writing-mode: vertical-rl; transform: rotate(180deg); color: #00ccff; font-weight: bold; cursor: pointer; font-size: 11px; text-decoration: none; letter-spacing: 1px;">
            <i class="fas fa-shield-alt" style="margin-bottom: 6px; transform: rotate(90deg); font-size: 13px;"></i> EQUIPO
        </a>

    </nav>

    {{!-- CUERPO DEL PANEL --}}
    <section class="dj-body" style="flex: 1; padding: 15px; overflow-y: auto; max-height: 100%;">

        {{!-- PESTAÑA 1: RADAR DE ALMAS --}}
        <div class="tab" data-group="primary" data-tab="radar">
            <div class="players-grid flexrow" style="gap: 15px; flex-wrap: wrap; justify-content: center; align-items: flex-start;">

                {{#if jugadores.length}}
                    {{#each jugadores as |jug|}}
                        <div class="player-card flexcol" style="background: rgba(0,0,0,0.8); padding: 10px; border: 1px solid #555; width: 260px; border-radius: 8px; box-shadow: 0 4px 10px rgba(0,0,0,0.8);">

                            {{!-- DATOS DEL PERSONAJE --}}
                            <div class="character-header flexrow" style="align-items: center; border-bottom: 1px solid #444; padding-bottom: 5px; margin-bottom: 8px;">
                                <img src="{{jug.actor.img}}" style="width: 30px; height: 30px; border-radius: 50%; object-fit: cover; border: 1px solid #888; margin-right: 8px;">
                                <span style="font-size: 16px; font-weight: bold; color: #ddd; flex: 1;">{{jug.actor.name}}</span>
                                <div title="Estabilidad" style="background: #222; padding: 2px 6px; border-radius: 4px; border: 1px solid #444; text-align: center;">
                                    <i class="fas fa-brain" style="color: #b388ff; font-size: 12px;"></i>
                                    <span style="color: white; font-weight: bold;">{{jug.system.estabilidad}}</span><span style="color: #666; font-size: 11px;">/22</span>
                                </div>
                            </div>

                            {{!-- EL ALMA --}}
                            <div style="position: relative;">
                                <img src="{{jug.alma.img}}" style="width: 100%; height: 120px; object-fit: cover; border: 2px solid gold; border-radius: 4px;">
                                <div style="position: absolute; bottom: 0; left: 0; right: 0; background: rgba(0,0,0,0.7); text-align: center; padding: 2px; font-weight: bold; font-size: 13px; color: gold;">
                                    {{jug.alma.name}}
                                </div>
                            </div>

                            {{!-- CONTROLES --}}
                            <div class="status-controls grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 5px; margin-top: 8px;">
                                <div class="stat-box flexcol" style="background: rgba(80,0,0,0.4); border: 1px solid #622; padding: 4px; text-align: center; border-radius: 3px;">
                                    <div style="font-size: 10px; color:#aaa;"><i class="fas fa-heart" style="color: #ff4444;"></i> VIDA</div>
                                    <div class="flexrow" style="align-items: center; justify-content: center; gap: 5px;">
                                        <a class="dj-control" data-actor-id="{{jug.actor.id}}" data-item-id="{{jug.alma.id}}" data-type="alma-vida" data-action="minus"><i class="fas fa-minus-square"></i></a>
                                        <b style="font-size: 14px; color: white;">{{jug.alma.system.vida.value}}/{{jug.alma.system.vida.max}}</b>
                                        <a class="dj-control" data-actor-id="{{jug.actor.id}}" data-item-id="{{jug.alma.id}}" data-type="alma-vida" data-action="plus"><i class="fas fa-plus-square"></i></a>
                                    </div>
                                </div>
                                <div class="stat-box flexcol" style="background: rgba(0,40,80,0.4); border: 1px solid #246; padding: 4px; text-align: center; border-radius: 3px;">
                                    <div style="font-size: 10px; color:#aaa;"><i class="fas fa-bolt" style="color: #00aaff;"></i> ENERGÍA</div>
                                    <div class="flexrow" style="align-items: center; justify-content: center; gap: 5px;">
                                        <a class="dj-control" data-actor-id="{{jug.actor.id}}" data-type="energia" data-action="minus"><i class="fas fa-minus-square"></i></a>
                                        <b style="font-size: 14px; color: white;">{{jug.system.energia.value}}</b>
                                        <a class="dj-control" data-actor-id="{{jug.actor.id}}" data-type="energia" data-action="plus"><i class="fas fa-plus-square"></i></a>
                                    </div>
                                </div>
                            </div>

                            <div class="stat-box flexcol" style="margin-top: 10px; background: rgba(50,30,80,0.4); border: 1px solid #538; padding: 5px; text-align: center; border-radius: 5px;">
                                <div class="flexrow" style="align-items: center; justify-content: center; gap: 10px;">
                                    <a class="dj-control" data-actor-id="{{jug.actor.id}}" data-type="estabilidad" data-action="minus" style="font-size: 18px; color: #ff6666;"><i class="fas fa-circle-minus"></i></a>
                                    <b style="font-size: 20px; color: white;">
                                        <i class="fas fa-brain" style="color: #b388ff; font-size: 16px; margin-right: 5px;"></i>{{jug.system.estabilidad}}
                                    </b>
                                    <a class="dj-control" data-actor-id="{{jug.actor.id}}" data-type="estabilidad" data-action="plus" style="font-size: 18px; color: #66ff66;"><i class="fas fa-circle-plus"></i></a>
                                </div>
                            </div>
                            {{!-- CARTAS ACTIVAS DEL JUGADOR (Poderes/Objetos con vida) --}}
                            {{#if jug.cartasVivas.length}}
                                <div style="border-top: 1px dashed #555; margin-top: 10px; padding-top: 5px;">
                                    <div style="font-size: 10px; color: #ffaa00; text-align: center; margin-bottom: 5px; font-weight: bold;">CARTAS ACTIVAS</div>

                                    <div class="cartas-vivas-scroll" style="max-height: 90px; overflow-y: auto; overflow-x: hidden; padding-right: 5px;">
                                        {{#each jug.cartasVivas as |carta|}}
                                            <div class="flexrow" style="background: rgba(139,0,0,0.3); border: 1px solid #8b0000; padding: 4px 6px; align-items: center; justify-content: space-between; border-radius: 4px; margin-bottom: 4px;">
                                                <span style="font-size: 11px; color: gold; font-weight: bold; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 120px;" title="{{carta.name}}">{{carta.name}}</span>

                                                <div class="flexrow" style="align-items: center; gap: 5px; flex: 0 0 auto;">
                                                    {{!-- Usamos ../actor.id para apuntar al ID del jugador --}}
                                                    <a class="dj-control" data-actor-id="{{../actor.id}}" data-item-id="{{carta.id}}" data-type="carta-vida" data-action="minus"><i class="fas fa-minus-square" style="color: #ff6666;"></i></a>
                                                    <b style="font-size: 13px; color: white;">{{carta.system.vida.value}}</b>
                                                    <a class="dj-control" data-actor-id="{{../actor.id}}" data-item-id="{{carta.id}}" data-type="carta-vida" data-action="plus"><i class="fas fa-plus-square" style="color: #66ff66;"></i></a>
                                                </div>
                                            </div>
                                        {{/each}}
                                    </div>
                                </div>
                            {{/if}}




                        </div>
                    {{/each}}
                {{else}}
                    <div style="text-align: center; color: #888; font-style: italic; margin-top: 40px; font-size: 18px;">
                        <p><i class="fas fa-ghost" style="font-size: 40px; margin-bottom: 10px;"></i></p>
                        Esperando invocaciones de Almas...
                    </div>
                {{/if}}
            </div>
        </div>

        {{!-- PESTAÑA 2: LA CRIATURA --}}
        <div class="tab" data-group="primary" data-tab="criatura">
            <div class="boss-section-container flexcol" style="height: 100%;">

                {{#if activeBoss}}
                    <div class="active-boss-panel flexrow" style="gap: 20px; align-items: flex-start;">

                        {{!-- IZQUIERDA: EL BOSS (Formato Ultra Compacto) --}}
                        <div class="boss-sidebar flexcol" style="flex: 0 0 200px; background: rgba(139,0,0,0.2); border: 1px solid #8b0000; padding: 10px; border-radius: 8px; text-align: center;">
                            <h3 style="color: gold; margin-bottom: 5px; border-bottom: 1px solid gold; font-size: 15px;">{{activeBoss.name}}</h3>

                            {{!-- Retrato de la criatura arrastrable --}}
                            <div class="boss-card-container item" data-item-id="{{bossAlma.id}}" style="position: relative; margin: 0 auto 8px auto; width: 125px; cursor: grab;" draggable="true">


                                <div class="boss-soul-display" style="flex: 0 0 100px; position: relative;">
                                    {{#if bossAlma}}
                                        <img src="{{bossAlma.img}}"  draggable="false" style="width: 100%; border: 2px solid #8b0000; border-radius: 5px; box-shadow: 0 0 10px rgba(139,0,0,0.5);">

                                        {{!-- NUEVO: BOTÓN DE TRANSFORMACIÓN --}}
                                        <div class="transform-boss"
                                             data-id-criatura="{{activeBoss.flags.dorso_oscuro.idCriatura}}"
                                             style="position: absolute; bottom: -5px; right: -5px; background: #4a0000; color: #ffcc00; border: 1px solid #ffcc00; border-radius: 50%; width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; cursor: pointer; z-index: 2; box-shadow: 0 0 5px black;"
                                             title="Cambiar Fase / Evolucionar">
                                            <i class="fas fa-sync-alt"></i>
                                        </div>
                                    {{/if}}
                                </div>
                                {{!-- Etiqueta visual Oculta Reactiva --}}
                                {{#if bossIsFaceDown}}
                                    <div style="position: absolute; top: 5px; right: 5px; background: rgba(0,0,0,0.6); color: gold; padding: 2px 5px; border-radius: 3px; font-size: 10px; border: 1px solid gold;">
                                        <i class="fas fa-eye-slash"></i> OCULTA
                                    </div>
                                {{/if}}
                            </div>

                            {{!-- VIDA (Con Input Directo en una sola línea) --}}
                            <div style="display: flex; flex-wrap: nowrap; align-items: center; justify-content: space-between; background: #400; padding: 4px 6px; border-radius: 4px; margin-bottom: 6px; border: 1px solid #822;">
                                <span style="font-size: 11px; color: #ff6666; font-weight: bold; white-space: nowrap;">
                                    <i class="fas fa-heart"></i> VIDA
                                </span>

                                <div style="display: flex; flex-wrap: nowrap; align-items: center; gap: 4px;">
                                    <input type="number" class="boss-life-input" data-actor-id="{{activeBoss.id}}" data-item-id="{{bossAlma.id}}" value="{{bossAlma.system.vida.value}}"
                                           style="width: 45px; height: 22px; padding: 0; text-align: center; background: rgba(50,0,0,0.8); color: white; border: 1px solid #ff4444; font-weight: bold; font-size: 13px; border-radius: 3px;"
                                           title="Escribe la vida y pulsa Enter">

                                    <span style="color: #888; font-size: 12px; font-weight: bold; white-space: nowrap;">
                                        / {{bossAlma.system.vida.max}}
                                    </span>

                                    <a class="boss-life-update" title="Aplicar Vida" style="cursor: pointer; background: #222; padding: 2px 5px; border-radius: 3px; border: 1px solid #ff4444; display: flex; align-items: center; justify-content: center; margin-left: 2px;">
                                        <i class="fas fa-sync-alt" style="color: #66ff66; font-size: 10px;"></i>
                                    </a>
                                </div>
                            </div>

                            {{!-- NUEVO: MALUS Y LIMPIAR (CRIATURA) --}}
                            <div style="display: flex; gap: 5px; margin-bottom: 6px;">
                                <div class="flexcol" style="background: rgba(139,0,0,0.4); border: 1px solid #822; padding: 4px; text-align: center; border-radius: 3px; flex: 1;">
                                    <div style="font-size: 9px; color:#aaa;" title="Merma"><i class="fas fa-angles-down" style="color: #aa5500;"></i> MERMA</div>
                                    <div class="flexrow" style="align-items: center; justify-content: center; gap: 5px;">
                                        <a class="dj-control" data-actor-id="{{activeBoss.id}}" data-type="merma" data-action="minus"><i class="fas fa-minus-square"></i></a>
                                        <b style="font-size: 13px; color: white;">{{activeBoss.system.merma}}</b>
                                        <a class="dj-control" data-actor-id="{{activeBoss.id}}" data-type="merma" data-action="plus"><i class="fas fa-plus-square"></i></a>
                                    </div>
                                </div>
                                <div class="flexcol" style="background: rgba(139,0,0,0.4); border: 1px solid #822; padding: 4px; text-align: center; border-radius: 3px; flex: 1;">
                                    <div style="font-size: 9px; color:#aaa;" title="Decadencia"><i class="fas fa-droplet" style="color: #aa0000;"></i> DECAD.</div>
                                    <div class="flexrow" style="align-items: center; justify-content: center; gap: 5px;">
                                        <a class="dj-control" data-actor-id="{{activeBoss.id}}" data-type="decadencia" data-action="minus"><i class="fas fa-minus-square"></i></a>
                                        <b style="font-size: 13px; color: white;">{{activeBoss.system.decadencia}}</b>
                                        <a class="dj-control" data-actor-id="{{activeBoss.id}}" data-type="decadencia" data-action="plus"><i class="fas fa-plus-square"></i></a>
                                    </div>
                                </div>
                            </div>
                            <button class="boss-clean-malus" data-actor-id="{{activeBoss.id}}" style="background: #225522; color: white; border: 1px solid #383; font-weight: bold; padding: 4px; cursor: pointer; width: 100%; font-size: 10px; margin-bottom: 6px;">
                                <i class="fas fa-hand-sparkles"></i> LIMPIAR ESTADOS
                            </button>

                            {{!-- BOTÓN (Reducido) --}}
                            <button class="close-boss-game" style="background: #222; color: #ff4444; border: 1px solid #ff4444; font-weight: bold; padding: 4px; cursor: pointer; width: 100%; font-size: 11px;">
                                <i class="fas fa-skull"></i> FIN ENCUENTRO
                            </button>
                        </div>

                        {{!-- DERECHA: MANO --}}
                        <div class="boss-actions flexcol" style="flex: 1; gap: 15px;">

                            {{!-- CABECERA DE CONTROL --}}
                            <div class="flexrow" style="background: rgba(0,0,0,0.4); padding: 8px; border-radius: 5px; border: 1px solid #444; justify-content: space-between; align-items: center; flex: 0 0 auto;">
                                <div style="color: #ccc; font-size: 12px;">Mazo: <b style="color: white;">{{bossMazoSize}}</b></div>
                                <div class="flexrow" style="gap: 5px; width: auto;">
                                    <button class="boss-draw-all" style="background: #8b0000; color: white; border: 1px solid #a00; padding: 4px 10px; font-size: 11px; cursor: pointer;"><i class="fas fa-layer-group"></i> ROBAR TODO</button>
                                    <button class="boss-end-turn" style="background: #225522; color: white; border: 1px solid #383; padding: 4px 10px; font-size: 11px; cursor: pointer;"><i class="fas fa-check-double"></i> FIN TURNO</button>
                                </div>
                            </div>

                            {{!-- CONTENEDOR DE DOS COLUMNAS (Poderes y Objetos) --}}
                            <div class="flexrow" style="gap: 20px; align-items: flex-start; flex: 1;">

                                {{!-- COLUMNA IZQUIERDA: PODERES --}}
                                <div class="hand-section flexcol" style="flex: 1;">
                                    <h4 style="color: #ffaa00; border-bottom: 1px solid #ffaa00; margin-bottom: 10px; font-size: 13px; padding-bottom: 3px;"><i class="fas fa-bolt"></i> PODERES ({{bossPoderes.length}})</h4>
                                    <div class="boss-hand flexrow" style="flex-wrap: wrap; gap: 10px;">
                                        {{#each bossPoderes as |c|}}
                                            <div class="boss-card-container item" data-item-id="{{c.id}}" style="width: 90px; height: 125px; flex: 0 0 auto; cursor: grab;" draggable="true">
                                                <img src="{{c.faces.[0].img}}" style="width: 100%; height: 100%; object-fit: cover; border-radius: 4px; border: 1px solid #000; box-shadow: 0 2px 5px rgba(0,0,0,0.5); pointer-events: none;" draggable="false">
                                            </div>
                                        {{/each}}
                                    </div>
                                </div>

                                {{!-- COLUMNA DERECHA: OBJETOS --}}
                                <div class="hand-section flexcol" style="flex: 1; border-left: 1px dashed #444; padding-left: 20px;">
                                    <h4 style="color: #00ccff; border-bottom: 1px solid #00ccff; margin-bottom: 10px; font-size: 13px; padding-bottom: 3px;"><i class="fas fa-suitcase"></i> OBJETOS ({{bossObjetos.length}})</h4>
                                    <div class="boss-hand flexrow" style="flex-wrap: wrap; gap: 10px;">
                                        {{#each bossObjetos as |c|}}
                                            <div class="boss-card-container item" data-item-id="{{c.id}}" style="width: 90px; height: 125px; flex: 0 0 auto; cursor: grab;" draggable="true">
                                                <img src="{{c.faces.[0].img}}" style="width: 100%; height: 100%; object-fit: cover; border-radius: 4px; border: 1px solid #000; box-shadow: 0 2px 5px rgba(0,0,0,0.5); pointer-events: none;" draggable="false">
                                            </div>
                                        {{/each}}
                                    </div>
                                </div>

                            </div>

                        </div>

                        {{!-- CARTAS ACTIVAS DE LA CRIATURA --}}
                        {{#if bossCartasVivas.length}}
                            <div style="border-top: 1px dashed #555; margin: 10px 0; padding-top: 5px;">
                                <div style="font-size: 10px; color: #ffaa00; text-align: center; margin-bottom: 5px; font-weight: bold;">CARTAS ACTIVAS (EN JUEGO)</div>

                                {{!-- Contenedor con scroll forzado --}}
                                <div class="cartas-vivas-scroll" style="max-height: 90px; overflow-y: auto; overflow-x: hidden; padding-right: 5px;">
                                    {{#each bossCartasVivas as |carta|}}
                                        <div class="flexrow" style="background: rgba(139,0,0,0.3); border: 1px solid #8b0000; padding: 4px 6px; align-items: center; justify-content: space-between; border-radius: 4px; margin-bottom: 4px;">
                                            <span style="font-size: 11px; color: gold; font-weight: bold; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 140px;" title="{{carta.name}}">{{carta.name}}</span>

                                            <div class="flexrow" style="align-items: center; gap: 5px; flex: 0 0 auto;">
                                                <a class="dj-control" data-actor-id="{{../activeBoss.id}}" data-item-id="{{carta.id}}" data-type="carta-vida" data-action="minus"><i class="fas fa-minus-square" style="color: #ff6666;"></i></a>
                                                <b style="font-size: 13px; color: white;">{{carta.system.vida.value}}</b>
                                                <a class="dj-control" data-actor-id="{{../activeBoss.id}}" data-item-id="{{carta.id}}" data-type="carta-vida" data-action="plus"><i class="fas fa-plus-square" style="color: #66ff66;"></i></a>
                                            </div>
                                        </div>
                                    {{/each}}
                                </div>
                            </div>
                        {{/if}}


                    </div>
                {{else}}

                    <h3 style="text-align: center; color: #ffaa00; margin-bottom: 20px;">SELECCIONA CRIATURA</h3>
                    <div class="creature-selection-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 15px;">
                        {{#each disponibles as |c|}}
                            <div class="select-boss flexcol" data-id="{{c.id}}" style="cursor: pointer; background: rgba(0,0,0,0.5); padding: 8px; border-radius: 8px; border: 1px solid #444; transition: all 0.2s; text-align: center; align-items: center;">
                                {{!-- Cambiado a height: 160px y object-fit: contain para que la carta se vea entera sin recortes --}}
                                <img src="{{c.img}}" style="width: 100%; height: 160px; object-fit: contain; border-radius: 4px; margin-bottom: 8px; drop-shadow: 0 2px 4px rgba(0,0,0,0.8);">
                                <b style="color: gold; font-size: 12px; line-height: 1.2;">{{c.name}}</b>
                            </div>
                        {{/each}}
                    </div>

                {{/if}}

            </div>
        </div>
        <!--3 PESTAÑA 3: EQUIPO -->
        <div class="tab" data-group="primary" data-tab="equipo">
            <h3 style="color: #00ccff; border-bottom: 1px solid #00ccff; margin-bottom: 15px;">Gestión de Cartas de Equipo</h3>
            <div class="equipo-grid flexrow" style="gap: 15px; flex-wrap: wrap;">
                {{#each cartasEquipoMundo as |eq|}}
                    <div class="equipo-item flexcol {{#unless eq.isUnlocked}}locked{{/unless}}"
                         style="width: 120px; position: relative; background: rgba(0,0,0,0.5); padding: 5px; border-radius: 5px; border: 1px solid {{#if eq.isUnlocked}}#00ccff{{else}}#444{{/if}};">

                        {{!-- Imagen de la carta (con filtro gris si está bloqueada) --}}
                        <div class="boss-card-container item" data-item-id="{{eq.id}}" draggable="{{#if eq.isUnlocked}}true{{else}}false{{/if}}" style="cursor: {{#if eq.isUnlocked}}grab{{else}}not-allowed{{/if}};">
                            <img src="{{eq.img}}" draggable="false" style="width: 100%; height: 160px; object-fit: contain; pointer-events: none; {{#unless eq.isUnlocked}}filter: grayscale(1) brightness(0.5);{{/unless}}">

                        </div>

                        <div style="font-size: 10px; text-align: center; margin-top: 5px; font-weight: bold;">{{eq.name}}</div>

                        {{!-- Botón de Desbloquear/Bloquear --}}
                        <button class="toggle-equipo" data-id="{{eq.id}}"
                                style="margin-top: 5px; font-size: 9px; padding: 2px; background: {{#if eq.isUnlocked}}#8b0000{{else}}#003366{{/if}}; color: white; border: none; cursor: pointer;">
                            {{#if eq.isUnlocked}}BLOQUEAR{{else}}DESBLOQUEAR{{/if}}
                        </button>
                    </div>
                {{/each}}
            </div>
            <p style="font-size: 11px; color: #888; margin-top: 15px; font-style: italic;">
                * Al desbloquear, los jugadores podrán ver la carta en su Mesa de Juego. Arrastra la carta al tablero para jugarla.
            </p>
        </div>

    </section>
</div>