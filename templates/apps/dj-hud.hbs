<div class="dj-hud-container flexcol" style="height: 100%; padding: 10px; background: rgba(20,20,20,0.9); color: white; border: 2px solid #8b0000; border-radius: 8px;">

    <h2 style="text-align: center; border-bottom: 2px solid #8b0000; color: #ff4444; padding-bottom: 5px;">
        <i class="fas fa-eye"></i> RADAR DE ALMAS
    </h2>

    <div class="players-grid flexrow" style="gap: 15px; flex-wrap: wrap; margin-top: 10px; justify-content: center;">
        {{#each jugadores as |jug|}}
            <div class="player-card flexcol" style="background: rgba(0,0,0,0.6); padding: 10px; border: 1px solid #444; width: 180px; text-align: center; border-radius: 5px;">
                <h3 style="margin-bottom: 5px; font-size: 16px; color: #ccc;">{{jug.actor.name}}</h3>

                {{#if jug.alma}}
                    <img src="{{jug.alma.img}}" style="width: 100%; height: 100px; object-fit: cover; border: 2px solid gold; border-radius: 4px;">
                    <span style="font-size: 14px; font-weight: bold; margin-top: 5px;">{{jug.alma.name}}</span>
                    <span style="color: #ff6666; font-size: 18px; font-weight: bold; margin-top: 5px;">Vida: {{jug.alma.system.vida.value}} / {{jug.alma.system.vida.max}}</span>
                {{else}}
                    <div style="height: 100px; border: 1px dashed #666; display: flex; align-items: center; justify-content: center;">
                        <span style="color: #666; font-style: italic;">Sin alma...</span>
                    </div>
                {{/if}}
            </div>
        {{/each}}
    </div>

</div>