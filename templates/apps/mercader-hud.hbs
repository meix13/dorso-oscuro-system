<div class="mercader-container flexcol" style="background: rgba(20,20,20,0.95); color: white; border: 2px solid #00ccff; border-radius: 8px; height: 100%; padding: 10px;">

    {{!-- 1. ZONA DE CONFIGURACIÓN --}}
    <div class="config-section flexcol" style="background: rgba(0, 204, 255, 0.1); border: 1px solid #00ccff; padding: 15px; border-radius: 8px; margin-bottom: 15px;">
        <h3 style="color: #00ccff; text-align: center; margin-top: 0; border-bottom: 1px dashed #00ccff; padding-bottom: 5px;">
            <i class="fas fa-store"></i> Parámetros de la Oferta
        </h3>

        <div class="flexrow" style="gap: 20px; align-items: flex-start;">
            {{!-- ... (Los checkboxes de mundos y los inputs numéricos se quedan igual) ... --}}
            <div class="flexcol" style="flex: 1;">
                <label style="color: #aaa; font-weight: bold; font-size: 12px; margin-bottom: 5px;">Mundos Activos:</label>
                <div class="grid" style="grid-template-columns: 1fr 1fr; gap: 5px;">
                    {{#each mundos as |m|}}
                        <label style="font-size: 12px; cursor: pointer;">
                            <input type="checkbox" class="mundo-checkbox" value="{{m.id}}" checked> {{m.nombre}}
                        </label>
                    {{/each}}
                </div>
            </div>

            <div class="flexcol" style="flex: 1; align-items: center; justify-content: center; gap: 10px;">
                <div class="flexrow" style="align-items: center; gap: 10px;">
                    <label style="font-weight: bold;">Nº Objetos:</label>
                    <input type="number" id="num-objetos" value="2" style="width: 50px; text-align: center; background: #111; color: white; border: 1px solid #444;">
                </div>
                <div class="flexrow" style="align-items: center; gap: 10px;">
                    <label style="font-weight: bold;">Nº Poderes:</label>
                    <input type="number" id="num-poderes" value="7" style="width: 50px; text-align: center; background: #111; color: white; border: 1px solid #444;">
                </div>
            </div>

            {{!-- NUEVA ZONA DE BOTONES DE CONTROL --}}
            <div class="flexcol" style="flex: 1; justify-content: center; gap: 5px;">
                <div class="flexrow" style="gap: 5px;">
                    <button id="btn-generar-oferta" style="flex: 2; background: #003366; color: #00ccff; border: 1px solid #00ccff; font-weight: bold; padding: 8px; cursor: pointer;" title="Generar una nueva oferta">
                        <i class="fas fa-magic"></i> GENERAR OFERTA
                    </button>
                    <button id="btn-limpiar-oferta" style="flex: 1; background: #4a0000; color: #ff6666; border: 1px solid #ff4444; font-weight: bold; padding: 8px; cursor: pointer;" title="Vaciar el escaparate actual">
                        <i class="fas fa-eraser"></i> LIMPIAR
                    </button>
                </div>

                <div class="flexrow" style="gap: 5px;">
                    <button id="btn-pasar-tablero" style="background: #225522; color: white; border: 1px solid #383; font-size: 10px; padding: 5px; cursor: pointer;" title="Coloca toda la oferta en el centro del tablero">
                        <i class="fas fa-layer-group"></i> PASAR A TABLERO
                    </button>
                    <button id="btn-recoger-tablero" style="background: #552222; color: white; border: 1px solid #833; font-size: 10px; padding: 5px; cursor: pointer;" title="Borra todos los tokens del mercader de la mesa">
                        <i class="fas fa-trash-sweep"></i> RECOGER MESA
                    </button>
                </div>
            </div>
        </div>
    </div>

    {{!-- 2. EL ESCAPARATE (La Oferta Generada) --}}
    <div class="oferta-section flexcol" style="flex: 1; overflow-y: auto;">

        <h4 style="color: gold; border-bottom: 1px solid gold; margin-bottom: 10px;">
            <i class="fas fa-suitcase"></i> Objetos en Venta
        </h4>
        <div class="flexrow" style="justify-content: flex-start; gap: 15px; flex-wrap: wrap; margin-bottom: 20px; min-height: 160px;">
            {{#if oferta.objetos.length}}
                {{#each oferta.objetos as |obj|}}
                {{!-- CORRECCIÓN CSS: flex: 0 0 110px para evitar el estiramiento --}}
                    <div class="mercader-card item" data-item-id="{{obj.id}}" draggable="true" style="flex: 0 0 110px; width: 110px; text-align: center; cursor: grab;">
                        <img src="{{obj.img}}" style="width: 100%; height: 150px; object-fit: cover; border: 2px solid gold; border-radius: 5px; pointer-events: none;" draggable="false">
                        <span style="font-size: 11px; font-weight: bold; color: #ddd; display: block; margin-top: 4px;">{{obj.name}}</span>
                    </div>
                {{/each}}
            {{else}}
                <span style="color: #666; font-style: italic;">Sin objetos generados...</span>
            {{/if}}
        </div>

        <h4 style="color: #ff4500; border-bottom: 1px solid #ff4500; margin-bottom: 10px;">
            <i class="fas fa-bolt"></i> Poderes en Venta
        </h4>
        <div class="flexrow" style="justify-content: flex-start; gap: 15px; flex-wrap: wrap; padding-bottom: 10px;">
            {{#if oferta.poderes.length}}
                {{#each oferta.poderes as |pod|}}
                {{!-- CORRECCIÓN CSS: flex: 0 0 110px para evitar el estiramiento --}}
                    <div class="mercader-card item" data-item-id="{{pod.id}}" draggable="true" style="flex: 0 0 110px; width: 110px; text-align: center; cursor: grab;">
                        <img src="{{pod.img}}" style="width: 100%; height: 150px; object-fit: cover; border: 2px solid #ff4500; border-radius: 5px; pointer-events: none;" draggable="false">
                        <span style="font-size: 11px; font-weight: bold; color: #ddd; display: block; margin-top: 4px;">{{pod.name}}</span>
                    </div>
                {{/each}}
            {{else}}
                <span style="color: #666; font-style: italic;">Sin poderes generados...</span>
            {{/if}}
        </div>

    </div>


</div>