{{!-- templates/parts/skill-list.hbs --}}
<ul class="skills-list">
    {{#each skills as |item|}}
        <li class="item skill-row" data-item-id="{{item._id}}">
            <div class="skill-main-info">
                <a class="tirar-habilidad">
                    <span class="skill-name">{{item.name}}</span>
                    <span class="skill-attr">[{{item.system.atributoBase}}]</span>
                </a>
            </div>

            {{!-- Añadimos flexrow y align-items para que la papelera quede alineada --}}
            <div class="skill-values" style="display: flex; align-items: center;">
                <input type="number" value="{{item.system.valorActual}}" data-edit="system.valorActual">
                <span class="sep" style="margin: 0 5px;">/</span>
                <span class="max">{{item.system.valorMax}}</span>

                {{!-- NUEVO: Botón de borrar --}}
                <a class="item-delete" style="margin-left: 15px; color: #8b0000; cursor: pointer;" title="Borrar Habilidad">
                    <i class="fas fa-trash"></i>
                </a>
            </div>
        </li>
    {{/each}}
</ul>