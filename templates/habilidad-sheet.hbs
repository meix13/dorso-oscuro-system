<form class="{{cssClass}} flexcol" autocomplete="off" style="background: rgba(15, 15, 20, 0.95); padding: 15px; height: 100%; color: #e0e0e0;">

    {{!-- CABECERA --}}
    <header class="sheet-header flexrow" style="align-items: center; border-bottom: 2px solid #00ccff; padding-bottom: 10px; margin-bottom: 15px; flex: 0 0 auto;">
        <i class="fas fa-cogs" style="font-size: 36px; color: #00ccff; margin-right: 15px; text-shadow: 0 0 8px rgba(0, 204, 255, 0.5);"></i>

        <h1 style="margin: 0; flex: 1;">
            {{!-- Bloqueamos el nombre para jugadores --}}
            <input name="name" type="text" value="{{item.name}}" placeholder="Nombre de la Habilidad" {{#unless isGM}}disabled{{/unless}} style="color: #00ccff; font-family: 'Kalam', cursive; font-size: 28px; background: transparent; border: none; width: 100%; padding: 0;" />
        </h1>
    </header>

    {{!-- CUERPO --}}
    <main class="sheet-body flexcol" style="flex: 1; overflow-y: auto;">

        <div class="stat-row flexrow" style="align-items: center; margin-bottom: 15px;">
            <label style="font-weight: bold; flex: 1.5; color: #ffaa00; font-size: 16px;"><i class="fas fa-brain"></i> ATRIBUTO BASE</label>
            {{!-- Bloqueamos el selector para jugadores --}}
            <select name="system.atributoBase" {{#unless isGM}}disabled{{/unless}} style="flex: 1; background: #222; color: #fff; border: 1px solid #444; padding: 5px; font-size: 14px;">
                {{selectOptions config.atributos selected=system.atributoBase}}
            </select>
        </div>

        <div class="stat-row flexrow" style="align-items: center; margin-bottom: 15px;">
            <label style="font-weight: bold; flex: 1.5; color: #ffaa00; font-size: 16px;"><i class="fas fa-tags"></i> TIPO HABILIDAD</label>
            {{!-- Bloqueamos el selector para jugadores --}}
            <select name="system.tipo" {{#unless isGM}}disabled{{/unless}} style="flex: 1; background: #222; color: #fff; border: 1px solid #444; padding: 5px; font-size: 14px;">
                {{selectOptions config.tipos selected=system.tipo}}
            </select>
        </div>

        <div class="stat-row flexrow" style="align-items: center; margin-bottom: 15px;">
            <label style="font-weight: bold; flex: 1.5; color: #ffaa00; font-size: 16px;"><i class="fas fa-crosshairs"></i> SE USA CON ARMAS</label>
            <input type="checkbox" name="system.se_usa_con_arma" {{checked system.se_usa_con_arma}} {{#unless isGM}}disabled{{/unless}} style="flex: 1; width: 20px; height: 20px;">
        </div>

        {{!-- PUNTOS: Visibles solo si pertenecen a un Actor. Editables por todos. --}}
        {{#if isOwned}}
            <div class="flexrow" style="gap: 20px; margin-bottom: 15px; border-top: 1px dashed #444; padding-top: 15px;">
                <div class="stat-row flexcol" style="flex: 1; text-align: center; background: rgba(0,0,0,0.3); padding: 10px; border-radius: 5px; border: 1px solid #66ff66;">
                    <label style="color: #66ff66; font-weight: bold; margin-bottom: 5px; font-size: 13px;"><i class="fas fa-bolt"></i> PUNTOS ACTUALES</label>
                    <input type="number" name="system.valorActual" value="{{system.valorActual}}" min="0" style="background: #111; color: #fff; border: none; border-bottom: 2px solid #66ff66; text-align: center; font-size: 22px; font-weight: bold;">
                </div>

                <div class="stat-row flexcol" style="flex: 1; text-align: center; background: rgba(0,0,0,0.3); padding: 10px; border-radius: 5px; border: 1px solid #444;">
                    <label style="color: #aaa; font-weight: bold; margin-bottom: 5px; font-size: 13px;">MÁXIMO</label>
                    <input type="number" name="system.valorMax" value="{{system.valorMax}}" min="1" max="12" style="background: #111; color: #aaa; border: none; border-bottom: 2px solid #444; text-align: center; font-size: 22px;">
                </div>
            </div>
        {{/if}}

        <div class="description-editor flexcol" style="margin-top: 5px; flex: 1; display: flex; flex-direction: column;">
            <label style="font-weight: bold; display: block; margin-bottom: 5px; color: #00ccff; border-bottom: 1px dashed #00ccff; padding-bottom: 5px; font-size: 16px;">
                <i class="fas fa-book-open"></i> DESCRIPCIÓN
            </label>

            {{!-- Magia aquí: button=false hace que el editor sea siempre activo e integrado, sin necesidad de lápiz --}}
            <div style="background: rgba(0,0,0,0.4); padding: 10px; border-radius: 5px; flex: 1; border: 1px solid #333; min-height: 150px; overflow-y: auto;">
                {{editor enrichedDescription target="system.descripcion" button=false owner=owner editable=isGM engine="prosemirror" collaborate=false}}
            </div>
        </div>

    </main>
</form>