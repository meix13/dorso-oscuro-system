<form class="{{cssClass}} flexcol mystery-paper-theme" autocomplete="off" style="padding: 25px 30px; height: 100%; position: relative;">

    {{!-- CABECERA --}}
    <header class="sheet-header flexrow" style="align-items: center; border-bottom: 2px solid {{#if isArma}}#8b0000{{else}}#2c4c68{{/if}}; padding-bottom: 10px; margin-bottom: 15px; flex: 0 0 auto; z-index: 1;">

        {{!-- MAGIA DE FOUNDRY: data-edit="img" abre el explorador de archivos --}}
        <img src="{{item.img}}" {{#if isGM}}data-edit="img" cursor: pointer;{{/if}} title="{{item.name}}" style="width: 55px; height: 55px; object-fit: cover; border-radius: 5px; border: 2px solid {{#if isArma}}#8b0000{{else}}#2c4c68{{/if}}; margin-right: 15px; background: transparent;" />

        <h1 style="margin: 0; flex: 1;">
            <input name="name" type="text" value="{{item.name}}" placeholder="Nombre del Ítem" {{#unless isGM}}disabled{{/unless}} style="color: #1a1a1a; font-family: 'Kalam', cursive; font-size: 28px; background: transparent; border: none; width: 100%; padding: 0;" />
        </h1>
    </header>

    {{!-- CUERPO --}}
    <main class="sheet-body flexcol" style="flex: 1; overflow-y: auto; z-index: 1;">

        {{!-- Fila de Atributos Numéricos --}}
        <div class="flexrow" style="gap: 20px; margin-bottom: 15px;">

            {{!-- Campo DAÑO (Texto para aceptar fórmulas como 1d6+1) --}}
            <div class="stat-row flexcol" style="flex: 1; text-align: center; background: rgba(0,0,0,0.05); padding: 10px; border-radius: 5px; border: 1px dashed rgba(0,0,0,0.4);">
                <label style="color: #8b0000; font-weight: bold; margin-bottom: 5px; font-size: 14px;">
                    <i class="fas fa-tint"></i> DAÑO
                </label>
                <input type="text" name="system.danio" value="{{system.danio}}" {{#unless isGM}}disabled{{/unless}} style="background: transparent; color: #1a1a1a; border: none; border-bottom: 2px solid #8b0000; text-align: center; font-size: 22px; font-weight: bold; font-family: monospace;">
            </div>

            {{!-- HABILIDAD ASOCIADA (Solo aparece si es un Arma) --}}
            {{#if isArma}}
                <div class="stat-row flexcol" style="flex: 1; text-align: center; background: rgba(0,0,0,0.05); padding: 10px; border-radius: 5px; border: 1px dashed rgba(0,0,0,0.4);">
                    <label style="color: #00ccff; font-weight: bold; margin-bottom: 5px; font-size: 14px;">
                        <i class="fas fa-brain"></i> HABILIDAD
                    </label>
                    <select name="system.habilidadAsociada" {{#unless isGM}}disabled{{/unless}} class="parchment-select">
                        {{selectOptions opcionesHabilidades selected=system.habilidadAsociada}}
                    </select>
                </div>
            {{/if}}

            {{!-- Campo PREPARACIÓN --}}
            <div class="stat-row flexcol" style="flex: 1; text-align: center; background: rgba(0,0,0,0.05); padding: 10px; border-radius: 5px; border: 1px dashed rgba(0,0,0,0.4);">
                <label style="color: #2c4c68; font-weight: bold; margin-bottom: 5px; font-size: 14px;">
                    <i class="fas fa-cog"></i> PREP.
                </label>
                <input type="number" name="system.preparacionNecesaria" value="{{system.preparacionNecesaria}}" {{#unless isGM}}disabled{{/unless}} style="background: transparent; color: #1a1a1a; border: none; border-bottom: 2px solid #2c4c68; text-align: center; font-size: 22px; font-weight: bold;">
            </div>

        </div>

        {{!-- El Editor de Texto Directo (Inline) --}}
        <div class="description-editor flexcol paper-editor-container" style="margin-top: 5px; flex: 1; display: flex; flex-direction: column;">
            <label style="font-weight: bold; display: block; margin-bottom: 5px; color: #1a1a1a; border-bottom: 1px dashed #1a1a1a; padding-bottom: 5px; font-size: 18px; font-family: 'Kalam', cursive;">
                <i class="fas fa-book-open"></i> DESCRIPCIÓN
            </label>

            <div style="background: rgba(255, 255, 255, 0.2); padding: 10px; border-radius: 5px; flex: 1; border: 1px solid rgba(0,0,0,0.2); min-height: 150px; overflow-y: auto; font-family: sans-serif; font-size: 14px; color: #1a1a1a;">
                {{!-- Pasamos editable=isGM para que solo el DJ pueda escribir --}}
                {{editor enrichedDescription target="system.descripcion" button=false owner=owner editable=isGM engine="prosemirror" collaborate=false}}
            </div>
        </div>

    </main>
</form>