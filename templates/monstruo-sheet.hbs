<form class="{{cssClass}} mystery-paper-theme flexcol" autocomplete="off" style="padding: 30px; position: relative; height: 100%; overflow-x: auto;">

    <img src="systems/dorso_oscuro/assets/esquina_monstruo.png" style="position: absolute; top: 15px; left: 15px; width: 120px; border: none; pointer-events: none; z-index: 10;" />

    <header style="text-align: center; border: none; margin-top: 10px; margin-bottom: 20px; min-width: 700px;">
        <input name="name" type="text" value="{{actor.name}}" placeholder="NOMBRE DEL MONSTRUO" style="text-align: center; font-size: 38px; height: auto; min-height: 55px; line-height: 1.3; text-transform: uppercase; color: #2c4c68; border: none; background: transparent; font-family: 'Kalam', cursive; letter-spacing: 2px;" />
    </header>

    <div class="flexrow" style="flex-wrap: nowrap; align-items: center; gap: 15px; margin-bottom: 20px; min-width: 700px;">

        <div style="flex: 2; display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: auto auto; gap: 15px 10px; align-items: center;">

            {{!-- FILA 1, COLUMNA 1: Físico --}}
            <div style="display: flex; align-items: center; justify-content: flex-end; gap: 8px;">
                <a class="rollable" data-atributo="fisico" title="Lanzar Físico" style="font-size: 20px; color: #1a1a1a; font-weight: bold; cursor: pointer; text-decoration: none; white-space: nowrap;">
                    <i class="fas fa-dice-d20" style="color: #1a1a1a; margin-right: 5px;"></i>Físico
                </a>
                <input type="number" name="system.fisico.mod" value="{{system.fisico.mod}}" style="width: 40px; height: 40px; text-align: center; font-size: 20px; border: 2px solid #1a1a1a; background: transparent; border-radius: 4px; flex-shrink: 0;">

                <div style="position: relative; width: 45px; height: 45px; flex-shrink: 0;">
                    <img src="systems/dorso_oscuro/assets/{{system.fisico.dado}}.png" style="width: 100%; height: 100%; opacity: 0.8; pointer-events: none; object-fit: contain;">
                    <select name="system.fisico.dado" style="position: absolute; top:0; left:0; width: 100%; height: 100%; opacity: 0; cursor: pointer;">
                        {{selectOptions config.opcionesDado selected=system.fisico.dado}}
                    </select>
                </div>
            </div>

            {{!-- FILA 1, COLUMNA 2: Protección --}}
            <div style="display: flex; align-items: center; justify-content: flex-start; gap: 8px;">
                <label style="font-size: 20px; color: #1a1a1a; font-weight: bold; width: 100px; cursor: default; white-space: nowrap;">Protección</label>
                <input type="number" name="system.proteccion" value="{{system.proteccion}}" style="width: 40px; height: 40px; text-align: center; font-size: 20px; border: 2px solid #1a1a1a; background: transparent; border-radius: 4px; flex-shrink: 0;">
            </div>

            {{!-- FILA 2, COLUMNA 1: Perseguir --}}
            <div style="display: flex; align-items: center; justify-content: flex-end; gap: 8px;">
                <a class="rollable" data-atributo="perseguir" title="Lanzar Perseguir" style="font-size: 20px; color: #1a1a1a; font-weight: bold; cursor: pointer; text-decoration: none; white-space: nowrap;">
                    <i class="fas fa-dice-d20" style="color: #1a1a1a; margin-right: 5px;"></i>Perseguir
                </a>
                <input type="number" name="system.perseguir.mod" value="{{system.perseguir.mod}}" style="width: 40px; height: 40px; text-align: center; font-size: 20px; border: 2px solid #1a1a1a; background: transparent; border-radius: 4px; flex-shrink: 0;">

                <div style="position: relative; width: 45px; height: 45px; flex-shrink: 0;">
                    <img src="systems/dorso_oscuro/assets/{{system.perseguir.dado}}.png" style="width: 100%; height: 100%; opacity: 0.8; pointer-events: none; object-fit: contain;">
                    <select name="system.perseguir.dado" style="position: absolute; top:0; left:0; width: 100%; height: 100%; opacity: 0; cursor: pointer;">
                        {{selectOptions config.opcionesDado selected=system.perseguir.dado}}
                    </select>
                </div>
            </div>

            {{!-- FILA 2, COLUMNA 2: Razonable --}}
            <div style="display: flex; align-items: center; justify-content: flex-start; gap: 8px;">
                <label style="font-size: 20px; color: #1a1a1a; font-weight: bold; width: 100px; cursor: default; white-space: nowrap;">Razonable</label>
                <input type="number" name="system.razonable" value="{{system.razonable}}" min="0" max="3" style="width: 40px; height: 40px; text-align: center; font-size: 20px; border: 2px solid #1a1a1a; background: transparent; border-radius: 4px; flex-shrink: 0;">
            </div>

        </div>

        {{!-- Columna Central: Escudo y Gota (TRUCO DE IMAGEN DE FONDO FIJA) --}}
        {{!-- Columna Central: Escudo y Gota (BLINDADA CONTRA FOUNDRY) --}}
        <div class="flexcol" style="flex: 0 0 130px; align-items: center; justify-content: space-around; gap: 20px; flex-shrink: 0;">

            {{!-- Escudo (Umbral) --}}
            <div title="Umbral" style="width: 120px; height: 120px; min-width: 120px; min-height: 120px; background-image: url('systems/dorso_oscuro/assets/icon_umbral.png'); background-size: contain; background-repeat: no-repeat; background-position: center; display: flex; justify-content: center; align-items: center; flex-shrink: 0;">
                <input type="number" name="system.umbral" value="{{system.umbral}}" style="width: 60px; height: 50px; font-size: 38px; border: none !important; background: transparent !important; box-shadow: none !important; outline: none !important; text-align: center; margin-top: -12px; color: #1a1a1a; font-weight: bold;">
            </div>

            {{!-- Gota (Vida/Esencia) --}}
            <div title="Vida / Esencia" style="width: 120px; height: 120px; min-width: 120px; min-height: 120px; background-image: url('systems/dorso_oscuro/assets/icon_esencia.png'); background-size: contain; background-repeat: no-repeat; background-position: center; display: flex; justify-content: center; align-items: center; flex-shrink: 0;">
                <input type="number" name="system.hp.value" value="{{system.hp.value}}" style="width: 60px; height: 50px; font-size: 38px; border: none !important; background: transparent !important; box-shadow: none !important; outline: none !important; text-align: center; margin-top: 25px; color: #1a1a1a; font-weight: bold;">
            </div>

        </div>

        {{!-- Columna Derecha --}}
        <div class="flexcol" style="flex: 0 0 200px; justify-content: center; align-items: center; flex-shrink: 0; gap: 15px;">
            <img src="{{actor.img}}" data-edit="img" title="Pincha para cambiar imagen" class="monster-portrait" style="flex: 0 0 auto;" />
            <a class="show-portrait" title="Ver imagen en grande / Compartir con Jugadores" style="font-size: 28px; color: #2c4c68; cursor: pointer; transition: transform 0.2s, color 0.2s;" onmouseover="this.style.transform='scale(1.2)'; this.style.color='#8b0000'" onmouseout="this.style.transform='scale(1)'; this.style.color='#2c4c68'">
                <i class="fas fa-eye"></i>
            </a>
        </div>
    </div>

    {{!-- SECCIÓN DE ATAQUES Y LORE --}}
    <div class="flexcol" style="flex: 1; position: relative; min-width: 700px;">
        <img src="systems/dorso_oscuro/assets/runa_central.png" style="position: absolute; top: 40%; left: 50%; transform: translate(-50%, -50%); width: 50%; opacity: 0.08; pointer-events: none; z-index: 0;" />

        {{!-- CABECERA ATAQUES --}}
        <div class="flexrow" style="justify-content: space-between; align-items: center; border-bottom: 2px solid rgba(0,0,0,0.2); margin-bottom: 10px; z-index: 1;">
            <h3 style="font-size: 26px; color: #2c4c68; margin: 0;">Ataques</h3>
            {{#if isGM}}
                <a class="ataque-create" style="cursor: pointer; color: #8b0000; font-weight: bold; font-size: 16px; font-family: sans-serif;"><i class="fas fa-plus-circle"></i> Añadir Ataque</a>
            {{/if}}
        </div>

        {{!-- LISTA DE ATAQUES DINÁMICA --}}
        <div class="ataques-list flexcol" style="gap: 10px; margin-bottom: 20px; z-index: 1;">
            {{#each system.ataques as |ataque index|}}
                <div class="ataque-item" style="background: rgba(255,255,255,0.4); border: 1px dashed rgba(0,0,0,0.4); border-radius: 5px; padding: 10px; font-family: sans-serif;">

                    {{#if @root.isGM}}
                    {{!-- MODO EDICIÓN (SOLO DJ) --}}
                        <div class="flexrow" style="gap: 10px; margin-bottom: 8px; align-items: center;">
                            <input type="text" name="system.ataques.{{index}}.nombre" value="{{ataque.nombre}}" placeholder="Nombre del Ataque" style="flex: 2; font-weight: bold; font-size: 16px; border-bottom: 1px solid #1a1a1a;">
                            <select name="system.ataques.{{index}}.tipo" style="flex: 1; background: transparent; border: 1px solid #1a1a1a; font-family: sans-serif;">
                                {{selectOptions @root.config.tiposAtaque selected=ataque.tipo}}
                            </select>
                            <a class="ataque-delete" data-index="{{index}}" style="color: #8b0000; flex: 0 0 20px; text-align: center; cursor: pointer;" title="Borrar Ataque"><i class="fas fa-trash"></i></a>
                        </div>

                        <div class="flexrow" style="gap: 10px; margin-bottom: 8px; align-items: center;">
                            <label style="flex: 0 0 60px; font-weight: bold; font-size: 14px;">Impacto:</label>
                            <input type="text" name="system.ataques.{{index}}.formulaAtaque" value="{{ataque.formulaAtaque}}" placeholder="1D6+2" style="flex: 1; text-align: center; border: 1px dashed #1a1a1a; font-family: monospace;">
                            <a class="roll-formula" data-formula="{{ataque.formulaAtaque}}" data-nombre="{{ataque.nombre}}" data-especial="{{ataque.especial}}" data-tipo="Impacto" title="Tirar Impacto" style="color: #2c4c68; font-size: 18px; cursor: pointer;"><i class="fas fa-crosshairs"></i></a>
                            <label style="flex: 0 0 50px; font-weight: bold; font-size: 14px; text-align: right; margin-right: 5px;">Daño:</label>
                            <input type="text" name="system.ataques.{{index}}.formulaDanio" value="{{ataque.formulaDanio}}" placeholder="1D8" style="flex: 1; text-align: center; border: 1px dashed #1a1a1a; font-family: monospace;">
                            <a class="roll-formula" data-formula="{{ataque.formulaDanio}}" data-nombre="{{ataque.nombre}}" data-especial="{{ataque.especial}}" data-tipo="Daño" title="Tirar Daño" style="color: #8b0000; font-size: 18px; cursor: pointer;"><i class="fas fa-tint"></i></a>

                        </div>

                        <div class="flexrow" style="align-items: flex-start; margin-top: 5px;">
                            <label style="flex: 0 0 60px; font-weight: bold; font-size: 14px; margin-top: 5px;">Especial:</label>
                            <textarea name="system.ataques.{{index}}.especial" placeholder="Efectos adicionales, veneno, parálisis..." style="flex: 1; font-style: italic; border: 1px dotted rgba(0,0,0,0.3); background: rgba(255,255,255,0.2); resize: vertical; min-height: 45px; font-family: sans-serif; font-size: 13px; padding: 5px;">{{ataque.especial}}</textarea>
                        </div>

                    {{else}}
                    {{!-- MODO LECTURA (JUGADORES) --}}
                        <div class="flexrow" style="align-items: center; border-bottom: 1px solid rgba(0,0,0,0.1); padding-bottom: 5px; margin-bottom: 5px;">
                            <div class="flexcol" style="flex: 2;">
                                <span style="font-weight: bold; font-size: 18px; color: #1a1a1a;">{{ataque.nombre}}</span>
                                <span style="font-size: 13px; color: #444;">{{ataque.tipo}}</span>
                            </div>
                            <div class="flexrow" style="flex: 1; align-items: center; justify-content: center; gap: 8px;">
                                <span style="font-size: 16px; font-weight: bold; font-family: monospace;">{{ataque.formulaAtaque}}</span>
                                <a class="roll-formula" data-formula="{{ataque.formulaAtaque}}" data-nombre="{{ataque.nombre}}" data-tipo="Impacto" title="Tirar Impacto" style="color: #2c4c68; font-size: 20px; cursor: pointer;"><i class="fas fa-crosshairs"></i></a>
                            </div>
                            <div class="flexrow" style="flex: 1; align-items: center; justify-content: center; gap: 8px;">
                                <span style="font-size: 16px; font-weight: bold; font-family: monospace;">{{ataque.formulaDanio}}</span>
                                <a class="roll-formula" data-formula="{{ataque.formulaDanio}}" data-nombre="{{ataque.nombre}}" data-tipo="Daño" title="Tirar Daño" style="color: #8b0000; font-size: 20px; cursor: pointer;"><i class="fas fa-tint"></i></a>
                            </div>
                        </div>
                        {{#if ataque.especial}}
                            <div style="font-size: 14px; font-style: italic; color: #444;">
                                * {{ataque.especial}}
                            </div>
                        {{/if}}
                    {{/if}}
                </div>
            {{/each}}

            {{#unless system.ataques.length}}
                <div style="text-align: center; color: #1a1a1a; font-style: italic; font-family: 'Kalam', cursive; font-size: 20px;">No hay ataques definidos.</div>
            {{/unless}}
        </div>

        <h3 style="font-size: 26px; color: #2c4c68; border-bottom: 2px solid rgba(0,0,0,0.2); margin-bottom: 5px; z-index: 1;">Descripción y Lore</h3>
        <div class="paper-editor-container" style="flex: 1; min-height: 150px; z-index: 1; font-family: sans-serif; font-size: 16px;">
            {{editor enrichedDescription target="system.descripcion" button=false owner=owner editable=editable engine="prosemirror" collaborate=false}}
        </div>
    </div>

</form>