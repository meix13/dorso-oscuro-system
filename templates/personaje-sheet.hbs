<form class="{{cssClass}} mystery-paper-theme" autocomplete="off">

    {{!-- MENÚ DE NAVEGACIÓN (LAS PESTAÑAS) --}}
    <nav class="sheet-tabs tabs" data-group="primary" style="display: flex; justify-content: center; gap: 20px; font-size: 24px; border-bottom: 2px solid #1a1a1a; margin-bottom: 20px;">
        <a class="item" data-tab="expediente" style="cursor: pointer; padding-bottom: 5px;">Expediente</a>
        <a class="item" data-tab="baraja" style="cursor: pointer; padding-bottom: 5px;">Baraja y Equipo</a>
    </nav>

    <section class="sheet-body">

        {{!-- PESTAÑA 1: EXPEDIENTE (Todo tu HTML anterior va aquí dentro) --}}
        <div class="tab" data-group="primary" data-tab="expediente">


            {{!-- PARTE SUPERIOR: Dados, Runas y Retrato --}}
            <header class="sheet-upper flexrow">

                {{!-- Dados Atributos --}}
                <div class="dice-column flexcol">
                    {{#each system.atributos as |dado key|}}
                        <div class="dice-row flexrow" style="position: relative;">
                            <span class="attribute-label">{{key}}</span>
                            <a class="tirar-atributo" data-atributo="{{key}}">
                                <img src="systems/dorso_oscuro/assets/{{dado}}.png" class="img-dado" />
                            </a>

                            {{!-- NUEVO: Botón para cambiar el dado --}}
                            <a class="cambiar-dado btn-editar-dado" data-atributo="{{key}}" title="Cambiar dado">
                                <i class="fas fa-pen-fancy"></i>
                            </a>
                        </div>
                    {{/each}}
                </div>

                {{!-- Decoración Rúnica --}}
                <div class="rune-separator">
                    <img src="systems/dorso_oscuro/assets/runa_central.png">
                </div>

                {{!-- Nombre y Foto Circular --}}
                <div class="portrait-column flexcol">
                    <h1 class="charname">
                        <input name="name" type="text" value="{{actor.name}}" placeholder="Nombre"/>
                    </h1>
                    <div class="portrait-container">
                        <img class="profile-img-circle" src="{{actor.img}}" data-edit="img" />
                    </div>
                </div>
            </header>

            {{!-- PARTE MEDIA: Stats, Umbral y Esencia --}}
            <section class="stats-mid flexrow">
                <div class="track-stats flexcol">
                    <div class="input-line">Estabilidad: <input type="number" name="system.estabilidad" value="{{system.estabilidad}}"> / 22</div>
                    <div class="input-line">Salud: <input type="number" name="system.hp.value" value="{{system.hp.value}}"> / {{system.hp.max}}</div>
                    <div class="input-line">Cordura: <input type="number" name="system.cordura" value="{{system.cordura}}"> / 5</div>
                    <div class="input-line">Crédito: <input type="number" name="system.credito" value="{{system.credito}}"></div>
                </div>

                <div class="icon-stats flexrow">
                    <div class="icon-group">
                        <label>Umbral</label>
                        <div class="icon-frame umbral-frame">
                            <input type="number" name="system.umbral" value="{{system.umbral}}">
                        </div>
                    </div>
                    <div class="icon-group">
                        <label>Esencia</label>
                        <div class="icon-frame esencia-frame">
                            <input type="number" name="system.esencia" value="{{system.esencia}}">
                        </div>
                    </div>
                </div>
            </section>

            {{!-- PARTE INFERIOR: Dos Columnas de Habilidades --}}
            <section class="skills-grid flexrow">
                {{!-- Columna Técnicas --}}
                <div class="skill-column">
                    <h3>Habilidades Técnicas</h3>
                    {{> "systems/dorso_oscuro/templates/parts/skill-list.hbs" skills=habilidadesTecnicas}}
                </div>

                {{!-- Columna Generales --}}
                <div class="skill-column">
                    <h3>Habilidades Generales</h3>
                    {{> "systems/dorso_oscuro/templates/parts/skill-list.hbs" skills=habilidadesGenerales}}
                </div>
            </section>

            {{!-- PIE: Armas y Notas --}}
            <footer class="sheet-footer flexrow">
                <div class="footer-box armas">
                    <h3>Armas</h3>
                    <div class="empty-placeholder">Listado vacío...</div>
                </div>
                <div class="footer-box notas">
                    <h3>Notas</h3>
                    <textarea name="system.notas">{{system.notas}}</textarea>
                </div>
            </footer>


        </div>

        <div class="tab" data-group="primary" data-tab="baraja">
            <div class="deck-container flexcol" style="gap: 20px;">
                <button class="open-hud-btn" style="margin-bottom: 10px; background: #4a3424; color: white;">
                    <i class="fas fa-play"></i> ENTRAR EN COMBATE (Abrir Mesa)
                </button>
                {{!-- 1. FILA SUPERIOR: ALMAS Y BANQUILLO --}}
                <div class="flexrow" style="gap: 20px; align-items: flex-start;">

                    {{!-- ALMAS (Izquierda) --}}
                    <div class="deck-section" style="flex: 2;">
                        <h3 style="border-bottom: 2px solid #4a3424; margin-bottom: 10px;">Almas Disponibles</h3>
                        <ul class="skills-list flexcol" style="gap: 5px;">
                            {{#each cartasAlma as |carta|}}
                                <li class="item skill-row" data-item-id="{{carta._id}}" style="padding: 5px 0;">
                                    <div class="skill-main-info flexrow">
                                        {{!-- CLASE card-thumbnail aplicada, eliminados width/height inline --}}
                                        <img src="{{carta.img}}" class="card-thumbnail">
                                        <h4 class="skill-name" style="margin:0; font-size: 18px;">{{carta.name}}</h4>
                                        <span class="skill-attr" style="margin-left: 10px;">[{{carta.system.elemento}}]</span>
                                    </div>
                                    <div class="item-controls flexrow" style="align-items: center; justify-content: flex-end; gap: 10px;">
                                        <a class="item-edit" title="Ver Carta"><i class="fas fa-eye"></i></a>
                                        {{#if @root.user.isGM}}
                                            <a class="item-delete" title="Borrar Alma" style="color: #8b0000;"><i class="fas fa-trash"></i></a>
                                        {{/if}}
                                    </div>
                                </li>
                            {{/each}}
                        </ul>
                    </div>

                    {{!-- BANQUILLO (Derecha) --}}
                    <div class="deck-section" style="flex: 1; border: 2px dashed #666; padding: 10px; background: rgba(0,0,0,0.03); border-radius: 8px;">
                        <h3 style="border-bottom: 2px solid #666; margin-bottom: 10px; text-align: center;">Banquillo (Máx 3)</h3>
                        <ul class="skills-list flexcol" style="gap: 8px;">
                            {{#each banquillo as |carta|}}
                                <li class="item flexrow" data-item-id="{{carta._id}}" style="align-items: center; background: #eee; padding: 5px 8px; border-radius: 4px; border: 1px solid #ccc;">
                                    <img src="{{carta.img}}" width="20" height="30" style="margin-right: 8px; border-radius: 2px; filter: grayscale(100%); object-fit: cover;">
                                    <span style="font-size: 14px; flex: 1; line-height: 1.1;">{{carta.name}}</span>
                                    <div class="item-controls flexrow" style="flex: 0 0 auto; gap: 8px;">
                                        <a class="item-edit" title="Ver Carta" style="color: #444;"><i class="fas fa-eye"></i></a>
                                        <a class="item-toggle-bench" title="Sacar del Banquillo" style="color: #4a3424;"><i class="fas fa-hand-holding-magic"></i></a>
                                    </div>
                                </li>
                            {{/each}}
                        </ul>
                    </div>
                </div>

                {{!-- 2. FILA MEDIA: OBJETOS (Ancho completo) --}}
                <div class="deck-section">
                    <h3 style="border-bottom: 2px solid #884400; margin-bottom: 10px;">Objetos Activos</h3>
                    {{!-- Usamos un grid para que si hay varios objetos se pongan en cajitas --}}
                    <ul class="skills-list" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px;">
                        {{#each barajaObjetos as |carta|}}
                            <li class="item skill-row" data-item-id="{{carta._id}}" style="padding: 5px; border: 1px solid rgba(0,0,0,0.1); background: rgba(255,255,255,0.3); border-radius: 4px;">
                                <div class="skill-main-info flexrow">
                                    {{!-- CLASE card-thumbnail aplicada --}}
                                    <img src="{{carta.img}}" class="card-thumbnail">
                                    <span class="skill-name" style="font-weight: bold; font-size: 16px;">{{carta.name}}</span>
                                </div>
                                <div class="item-controls flexrow" style="align-items: center; justify-content: flex-end; gap: 10px;">
                                    <a class="item-toggle-bench" title="Al Banquillo"><i class="fas fa-suitcase"></i></a>
                                    <a class="item-edit" title="Ver Carta"><i class="fas fa-eye"></i></a>
                                    {{#if @root.user.isGM}}
                                        <a class="item-delete" title="Borrar Objeto" style="color: #8b0000;"><i class="fas fa-trash"></i></a>
                                    {{/if}}
                                </div>
                            </li>
                        {{/each}}
                    </ul>
                </div>

                {{!-- 3. FILA INFERIOR: PODERES (Ancho completo a DOS COLUMNAS) --}}
                <div class="deck-section">
                    <h3 style="border-bottom: 2px solid #004488; margin-bottom: 10px;">Poderes Activos ({{barajaPoderes.length}})</h3>
                    {{!-- GRID DE 2 COLUMNAS para optimizar las 30 cartas --}}
                    <ul class="skills-list" style="display: grid; grid-template-columns: 1fr 1fr; gap: x 15px; column-gap: 30px;">
                        {{#each barajaPoderes as |carta|}}
                            <li class="item skill-row" data-item-id="{{carta._id}}" style="padding: 4px 0;">
                                <div class="skill-main-info flexrow">
                                    {{!-- CLASE card-thumbnail aplicada --}}
                                    <img src="{{carta.img}}" class="card-thumbnail">
                                    <span class="skill-name" style="font-size: 16px;">{{carta.name}}</span>
                                </div>
                                <div class="item-controls flexrow" style="align-items: center; justify-content: flex-end; gap: 10px;">
                                    <a class="item-toggle-bench" title="Al Banquillo"><i class="fas fa-suitcase"></i></a>
                                    <a class="item-edit" title="Ver Carta"><i class="fas fa-eye"></i></a>
                                    {{#if @root.user.isGM}}
                                        <a class="item-delete" title="Borrar Poder" style="color: #8b0000;"><i class="fas fa-trash"></i></a>
                                    {{/if}}
                                </div>
                            </li>
                        {{/each}}
                    </ul>
                </div>

            </div>
        </div>

    </section>
</form>
